{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "发布博客",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}\\deploy.ps1"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "本地预览",
            "type": "shell",
            "command": "hugo",
            "args": ["server", "-D"],
            "group": "test",
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "新建文章",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}\\new-post.ps1", "-Title", "${input:postTitle}"],
            "group": "none"
        }
    ],
    "inputs": [
        {
            "id": "postTitle",
            "type": "promptString",
            "description": "输入文章标题",
            "default": "未命名文章"
        }
    ]
}
