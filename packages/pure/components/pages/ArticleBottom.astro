---
import type { CollectionEntry, CollectionKey } from 'astro:content'

import { cn } from '../../utils'

type Props = {
  id: string
  collections: CollectionEntry<CollectionKey>[]
  class?: string
}

// Get the requested entry
const { id, collections, class: className } = Astro.props
const path = Astro.url.pathname.split('/').slice(0, 2).join('/')

// Get the current post
const currentPost = collections.find((x) => x.id === id)

// Derive category from file path
function getCategory(entry: CollectionEntry<CollectionKey>): string | undefined {
  const sourceId = entry.filePath
    ? entry.filePath.replace(/^.*?src\/content\/blog\//, '').replace(/\.(md|mdx)$/, '')
    : entry.id.replace(/\.(md|mdx)$/, '')
  const sep = sourceId.lastIndexOf('/')
  return sep === -1 ? undefined : sourceId.slice(0, sep)
}

const currentCategory = currentPost ? getCategory(currentPost) : undefined

// Filter posts in the same category, sort by date
const sameCategoryPosts = currentCategory
  ? collections
      .filter((p) => getCategory(p) === currentCategory)
      .sort((a, b) => a.data.publishDate.getTime() - b.data.publishDate.getTime())
  : collections

// Find prev and next within the category
const index = sameCategoryPosts.findIndex((x) => x.id === id)
const prev = sameCategoryPosts[index - 1]
const next = sameCategoryPosts[index + 1]

const getEntryPath = (entry: CollectionEntry<CollectionKey>) => {
  const sourceId = entry.filePath
    ? entry.filePath.replace(/^.*?src\/content\/blog\//, '').replace(/\.(md|mdx)$/, '')
    : entry.id.replace(/\.(md|mdx)$/, '')
  return sourceId.replace(/\/index$/, '')
}
---

<div class={cn('flex max-sm:flex-col sm:justify-between gap-2', className)}>
  <span class='min-w-0'>
    {
      prev && (
        <a
          href={`${path}/${getEntryPath(prev)}`}
          class='group inline-flex items-center gap-x-2 rounded-xl px-4 py-2 no-underline transition-colors duration-300 hover:bg-muted max-sm:max-w-[80%] sm:flex'
        >
          <svg
            xmlns='http://www.w3.org/2000/svg'
            width='20'
            height='20'
            viewBox='0 0 24 24'
            fill='none'
            stroke-width='2.5'
            stroke-linecap='round'
            stroke-linejoin='round'
            class='shrink-0 rotate-180 stroke-muted-foreground transition-colors group-hover:stroke-primary'
          >
            <line
              x1='5'
              y1='12'
              x2='19'
              y2='12'
              class='translate-x-4 scale-x-0 transition-all duration-300 ease-in-out group-hover:translate-x-1 group-hover:scale-x-100'
            />
            <polyline
              points='12 5 19 12 12 19'
              class='translate-x-0 transition-all duration-300 ease-in-out group-hover:translate-x-1'
            />
          </svg>
          <p class='truncate font-medium transition-colors'>{prev.data.title}</p>
        </a>
      )
    }
  </span>

  <span class='min-w-0'>
    {
      next && (
        <a
          href={`${path}/${getEntryPath(next)}`}
          class='group inline-flex items-center gap-x-2 rounded-xl px-4 py-2 text-right no-underline transition-colors duration-300 hover:bg-muted max-sm:float-end max-sm:max-w-[80%] sm:flex'
        >
          <p class='truncate font-medium transition-colors'>{next.data.title}</p>
          <svg
            xmlns='http://www.w3.org/2000/svg'
            width='20'
            height='20'
            viewBox='0 0 24 24'
            fill='none'
            stroke-width='2.5'
            stroke-linecap='round'
            stroke-linejoin='round'
            class='shrink-0 stroke-muted-foreground transition-colors group-hover:stroke-primary'
          >
            <line
              x1='5'
              y1='12'
              x2='19'
              y2='12'
              class='translate-x-4 scale-x-0 transition-all duration-300 ease-in-out group-hover:translate-x-1 group-hover:scale-x-100'
            />
            <polyline
              points='12 5 19 12 12 19'
              class='translate-x-0 transition-all duration-300 ease-in-out group-hover:translate-x-1'
            />
          </svg>
        </a>
      )
    }
  </span>
</div>
