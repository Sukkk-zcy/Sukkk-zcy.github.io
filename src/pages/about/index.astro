---
import PageLayout from '@/layouts/CommonPage.astro'

const headings = [
  { depth: 2, slug: 'about-me', text: '关于我' },
  { depth: 2, slug: 'skills', text: '技术方向' },
  { depth: 2, slug: 'contact', text: '联系方式' },
  { depth: 2, slug: 'about-blog', text: '关于博客' }
]
---

<PageLayout title='关于' {headings} view comment hideBack hideTitle>
  <div class='mt-6 mb-16 flex flex-col items-start'>
    <div
      class='inline-block rounded-full bg-primary/10 px-3 py-1 text-sm font-medium text-primary mb-4'
    >
      Hello World
    </div>
    <h1 class='text-4xl font-bold tracking-tight text-foreground sm:text-6xl mb-4'>
      关于我 / About Me
    </h1>
    <p class='text-xl text-muted-foreground font-medium'>记录技术笔记和成长历程</p>
  </div>

  {/* About Me */}
  <div class='group flex flex-col overflow-hidden rounded-3xl border border-border/40 bg-background/40 backdrop-blur-md shadow-sm transition-all duration-500 hover:-translate-y-1 hover:border-transparent hover:shadow-[0_10px_30px_-10px_var(--primary)] mb-10'>
    <div class='p-6 sm:p-8 pt-5 sm:pt-7'>
      <h2 id='about-me' class='mt-0 mb-6 flex items-center gap-2'>
        <span class='text-2xl'>关于我</span>
      </h2>
      <div class='text-muted-foreground leading-relaxed space-y-4'>
        <p class='text-lg font-medium text-foreground tracking-wide'>
          SDN & IoT @SUES
        </p>
        <p>
          记录，思考，实践。
        </p>
      </div>
    </div>
  </div>

  {/* Skills */}
  <div class='group flex flex-col overflow-hidden rounded-3xl border border-border/40 bg-background/40 backdrop-blur-md shadow-sm transition-all duration-500 hover:-translate-y-1 hover:border-transparent hover:shadow-[0_10px_30px_-10px_var(--primary)] mb-10'>
    <div class='p-6 sm:p-8 pt-5 sm:pt-7'>
      <h2 id='skills' class='mt-0 mb-6 flex items-center gap-2'>
        <span class='text-2xl'>技术方向</span>
      </h2>
      <div class='flex flex-wrap gap-2'>
        <span class='rounded-lg border bg-background/50 px-3 py-1.5 text-sm backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:bg-muted shadow-sm'>SDN/P4</span>
        <span class='rounded-lg border bg-background/50 px-3 py-1.5 text-sm backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:bg-muted shadow-sm'>嵌入式开发</span>
        <span class='rounded-lg border bg-background/50 px-3 py-1.5 text-sm backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:bg-muted shadow-sm'>IOT</span>
        <span class='rounded-lg border bg-background/50 px-3 py-1.5 text-sm backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:bg-muted shadow-sm'>Python</span>
        <span class='rounded-lg border bg-background/50 px-3 py-1.5 text-sm backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:bg-muted shadow-sm'>Docker</span>
        <span class='rounded-lg border bg-background/50 px-3 py-1.5 text-sm backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:bg-muted shadow-sm'>Linux</span>
        <span class='rounded-lg border bg-background/50 px-3 py-1.5 text-sm backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:bg-muted shadow-sm'>ESP32</span>
      </div>
    </div>
  </div>

  {/* Contact */}
  <div class='group flex flex-col overflow-hidden rounded-3xl border border-border/40 bg-background/40 backdrop-blur-md shadow-sm transition-all duration-500 hover:-translate-y-1 hover:border-transparent hover:shadow-[0_10px_30px_-10px_var(--primary)] mb-10'>
    <div class='p-6 sm:p-8 pt-5 sm:pt-7'>
      <h2 id='contact' class='mt-0 mb-6 flex items-center gap-2'>
        <span class='text-2xl'>联系方式</span>
      </h2>
      <div class='flex flex-col gap-3'>
        <div class='flex items-center gap-3'>
          <span class='text-lg'>📧</span>
          <span class='text-muted-foreground'>sukkkzcy@gmail.com</span>
        </div>
        <div class='flex items-center gap-3'>
          <span class='text-lg'>💻</span>
          <a href='https://github.com/Sukkk-zcy' class='text-primary hover:underline' target='_blank'>GitHub: Sukkk-zcy</a>
        </div>
        <div class='flex items-center gap-3'>
          <span class='text-lg'>✈️</span>
          <a href='https://t.me/sukkkzcy' class='text-primary hover:underline' target='_blank'>Telegram: @sukkkzcy</a>
        </div>
      </div>
    </div>
  </div>

  {/* About Blog */}
  <div class='group flex flex-col overflow-hidden rounded-3xl border border-border/40 bg-background/40 backdrop-blur-md shadow-sm transition-all duration-500 hover:-translate-y-1 hover:border-transparent hover:shadow-[0_10px_30px_-10px_var(--primary)] mb-10'>
    <div class='p-6 sm:p-8 pt-5 sm:pt-7'>
      <h2 id='about-blog' class='mt-0 mb-6 flex items-center gap-2'>
        <span class='text-2xl'>关于博客</span>
      </h2>
      <div class='text-muted-foreground leading-relaxed space-y-4'>
        <p>
          本博客使用 <a href='https://astro.build/' class='text-primary hover:underline' target='_blank'>Astro</a> 搭建，主题基于 <a href='https://github.com/LemonAdorable/astro-theme-iris' class='text-primary hover:underline' target='_blank'>Iris Theme</a>。
        </p>
      </div>
    </div>
  </div>
</PageLayout>
